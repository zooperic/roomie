# ─── Project Roomy — Environment Variables ───────────────────────────────────
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: claude | openai | ollama
LLM_PROVIDER=claude

# Override model (leave blank to use provider default — cheapest capable tier)
# claude default  → claude-haiku-4-5-20251001
# openai default  → gpt-4o-mini
# ollama default  → llama3.2
LLM_MODEL=

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Ollama (local) ────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
# Your personal Telegram user ID (get it from @userinfobot)
# Comma-separated for multiple users
ALLOWED_TELEGRAM_USER_IDS=

# ── Swiggy MCP ────────────────────────────────────────────────────────────────
SWIGGY_MCP_API_KEY=
SWIGGY_MCP_BASE_URL=https://api.swiggy.com/mcp/v1

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (Phase 1 — zero setup)
DATABASE_URL=sqlite:///./data/roomy.db
# PostgreSQL (Phase 4 — uncomment when migrating)
# DATABASE_URL=postgresql://user:password@localhost:5432/roomy

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Service URLs (internal) ───────────────────────────────────────────────────
ALFRED_URL=http://localhost:8000
ELSA_URL=http://localhost:8001

# ── Webhook (for Telegram in production) ──────────────────────────────────────
# Set this to your ngrok URL (e.g., https://abc123.ngrok.io)
# Leave blank to use polling mode (fine for local dev)
WEBHOOK_URL=
